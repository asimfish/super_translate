# Translation API keys (at least one required for non-Google translation).
# The PAPER_CHINA_ prefix works everywhere (shell export, .env, Docker).
PAPER_CHINA_DEEPSEEK_API_KEY=
# PAPER_CHINA_OPENAI_API_KEY=
# PAPER_CHINA_MOONSHOT_API_KEY=
# PAPER_CHINA_DEEPL_API_KEY=

# Optional: Custom model/base URL
# DEEPSEEK_MODEL=deepseek-v4-pro
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OLLAMA_HOST=http://localhost:11434

# --- Required for any public (non-localhost) deployment ---
# Strong random bearer token; clients send "Authorization: Bearer <token>".
# Generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# PAPER_CHINA_API_TOKEN=
# Public URL used in notification links, e.g. https://translate.example.com
# PAPER_CHINA_BASE_URL=http://localhost:8001

# Optional: multi-workspace isolation ("lab-a:token-a,lab-b:token-b")
# PAPER_CHINA_WORKSPACE_TOKENS=

# Optional: Server settings
# PAPER_CHINA_DEBUG=true
# PAPER_CHINA_ALLOW_UNAUTHENTICATED_REMOTE=false
# Enable ONLY behind a reverse proxy you control (the bundled Caddy setup),
# so rate limiting counts real client IPs from X-Forwarded-For.
# PAPER_CHINA_TRUST_PROXY=true
# PAPER_CHINA_RATE_LIMIT_PER_MINUTE=60
# PAPER_CHINA_RATE_LIMIT_PER_HOUR=500
# Code default is 1; raise only if your API key tolerates parallel jobs.
# PAPER_CHINA_MAX_CONCURRENT_TRANSLATIONS=1
# Parallel supplier calls inside one translation; set 1 for rate-limited keys.
# PAPER_CHINA_TRANSLATION_CONCURRENCY=4

# Optional: custom CJK font for translated text (auto-discovered otherwise)
# PDF_ZH_FONT_FILE=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
